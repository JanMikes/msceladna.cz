{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Projekt"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "projectNumber": {
      "type": "string"
    },
    "goal": {
      "type": "richtext"
    },
    "financialAmount": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "logos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "publicityPoster": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files", "images", "videos", "audios"]
    },
    "status": {
      "type": "enumeration",
      "enum": ["aktivni", "ukonceny"]
    },
    "dateFrom": {
      "type": "date"
    },
    "dateTo": {
      "type": "date"
    },
    "workplaces": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::workplace.workplace"
    }
  }
}
