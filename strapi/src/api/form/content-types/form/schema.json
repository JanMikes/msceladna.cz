{
  "kind": "collectionType",
  "collectionName": "forms",
  "info": {
    "singularName": "form",
    "pluralName": "forms",
    "displayName": "Formulář"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "submitButtonText": {
      "type": "string",
      "default": "Odeslat"
    },
    "successMessage": {
      "type": "text",
      "default": "Formulář byl úspěšně odeslán. Děkujeme!"
    },
    "inputGroups": {
      "type": "component",
      "repeatable": true,
      "component": "form.input-group",
      "required": true
    }
  }
}
